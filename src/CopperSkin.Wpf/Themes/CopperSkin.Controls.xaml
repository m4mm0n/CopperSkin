<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
  <!-- copperskin:allow-hardcoded-color-file default seed dictionary -->

  <SolidColorBrush x:Key="color.surface.deep" Color="#FF171221"/>
  <SolidColorBrush x:Key="color.surface.panel" Color="#FF241B32"/>
  <SolidColorBrush x:Key="color.surface.control" Color="#FF342640"/>
  <SolidColorBrush x:Key="color.surface.hover" Color="#FF49345B"/>
  <SolidColorBrush x:Key="color.surface.selected" Color="#FF5F3F78"/>
  <SolidColorBrush x:Key="color.accent.primary" Color="#FFB961FF"/>
  <SolidColorBrush x:Key="color.accent.light" Color="#FFFFA1F7"/>
  <SolidColorBrush x:Key="color.border.default" Color="#FF735A8C"/>
  <SolidColorBrush x:Key="color.text.primary" Color="#FFF9F2FF"/>
  <SolidColorBrush x:Key="color.text.secondary" Color="#FFD5BEDF"/>
  <SolidColorBrush x:Key="color.text.disabled" Color="#FF806B8F"/>
  <SolidColorBrush x:Key="color.status.success" Color="#FF59D98E"/>
  <SolidColorBrush x:Key="color.status.warning" Color="#FFFFCC44"/>
  <SolidColorBrush x:Key="color.status.danger" Color="#FFFF4466"/>

  <LinearGradientBrush x:Key="CopperSkin.ChromeBrush" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FF41304D" Offset="0"/>
    <GradientStop Color="#FF261B31" Offset="0.52"/>
    <GradientStop Color="#FF15111C" Offset="1"/>
  </LinearGradientBrush>
  <LinearGradientBrush x:Key="CopperSkin.PanelBrush" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FF322542" Offset="0"/>
    <GradientStop Color="#FF211A2D" Offset="1"/>
  </LinearGradientBrush>
  <LinearGradientBrush x:Key="CopperSkin.StripBrush" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#FF3B2A4E" Offset="0"/>
    <GradientStop Color="#FF231B30" Offset="0.62"/>
    <GradientStop Color="#FF191520" Offset="1"/>
  </LinearGradientBrush>
  <LinearGradientBrush x:Key="CopperSkin.ActiveBrush" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FFFFA1F7" Offset="0"/>
    <GradientStop Color="#FFB961FF" Offset="0.45"/>
    <GradientStop Color="#FF7447C7" Offset="1"/>
  </LinearGradientBrush>
  <LinearGradientBrush x:Key="CopperSkin.ButtonShine" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#55FFFFFF" Offset="0"/>
    <GradientStop Color="#00FFFFFF" Offset="0.42"/>
    <GradientStop Color="#24000000" Offset="1"/>
  </LinearGradientBrush>
  <LinearGradientBrush x:Key="CopperSkin.PanelSheen" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#18FFFFFF" Offset="0"/>
    <GradientStop Color="#00000000" Offset="0.34"/>
    <GradientStop Color="#22000000" Offset="1"/>
  </LinearGradientBrush>
  <DropShadowEffect x:Key="CopperSkin.SoftGlow" BlurRadius="12" ShadowDepth="0" Opacity="0.42" Color="#FFFFA1F7"/>
  <DropShadowEffect x:Key="CopperSkin.PanelShadow" BlurRadius="18" ShadowDepth="1" Opacity="0.34" Color="#FF000000"/>
  <DropShadowEffect x:Key="CopperSkin.NeonGlow" BlurRadius="16" ShadowDepth="0" Opacity="0.58" Color="#FFFFA1F7"/>

  <Style TargetType="{x:Type Window}">
    <Setter Property="Background" Value="{DynamicResource color.surface.deep}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="FontFamily" Value="Segoe UI"/>
    <Setter Property="FontSize" Value="12"/>
  </Style>

  <Style TargetType="{x:Type TextBlock}">
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="FontFamily" Value="Segoe UI"/>
    <Setter Property="FontSize" Value="12"/>
  </Style>

  <Style TargetType="{x:Type Label}">
    <Setter Property="Foreground" Value="{DynamicResource color.text.secondary}"/>
    <Setter Property="Padding" Value="2"/>
  </Style>

  <Style TargetType="{x:Type ContentControl}">
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="FontFamily" Value="Segoe UI"/>
  </Style>

  <Style TargetType="{x:Type HeaderedContentControl}" BasedOn="{StaticResource {x:Type ContentControl}}">
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
  </Style>

  <Style x:Key="CopperSkin.SectionTitle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
    <Setter Property="Foreground" Value="{DynamicResource color.accent.light}"/>
    <Setter Property="FontSize" Value="15"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Margin" Value="0,0,0,8"/>
  </Style>

  <Style x:Key="CopperSkin.PanelBorder" TargetType="{x:Type Border}">
    <Setter Property="Background" Value="{DynamicResource CopperSkin.StripBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="7"/>
    <Setter Property="Padding" Value="12"/>
    <Setter Property="Effect" Value="{DynamicResource CopperSkin.PanelShadow}"/>
  </Style>

  <Style TargetType="{x:Type Button}">
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="10,5"/>
    <Setter Property="MinHeight" Value="28"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
            <Grid>
              <Border Background="{DynamicResource CopperSkin.ButtonShine}" CornerRadius="3" Opacity="0.72"/>
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Background" Value="{DynamicResource color.surface.hover}"/>
              <Setter Property="BorderBrush" Value="{DynamicResource color.accent.primary}"/>
              <Setter TargetName="Root" Property="Effect" Value="{DynamicResource CopperSkin.SoftGlow}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter Property="Background" Value="{DynamicResource color.accent.primary}"/>
              <Setter Property="Foreground" Value="#FFFFFFFF"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="{DynamicResource color.text.disabled}"/>
              <Setter TargetName="Root" Property="Opacity" Value="0.55"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="{x:Type RepeatButton}" BasedOn="{StaticResource {x:Type Button}}">
    <Setter Property="Padding" Value="5,2"/>
    <Setter Property="MinHeight" Value="22"/>
  </Style>

  <Style TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource {x:Type Button}}">
    <Style.Triggers>
      <Trigger Property="IsChecked" Value="True">
        <Setter Property="Background" Value="{DynamicResource color.accent.primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource color.accent.light}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="{x:Type TextBox}">
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="6,4"/>
    <Setter Property="CaretBrush" Value="{DynamicResource color.accent.primary}"/>
    <Setter Property="SelectionBrush" Value="{DynamicResource color.accent.primary}"/>
    <Setter Property="FontFamily" Value="Consolas"/>
  </Style>

  <Style TargetType="{x:Type RichTextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
    <Setter Property="FontFamily" Value="Consolas"/>
    <Setter Property="MinHeight" Value="64"/>
  </Style>

  <Style TargetType="{x:Type PasswordBox}">
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="6,4"/>
  </Style>

  <Style TargetType="{x:Type ComboBox}">
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="Padding" Value="6,4"/>
    <Setter Property="MinHeight" Value="28"/>
  </Style>

  <Style TargetType="{x:Type ComboBoxItem}">
    <Setter Property="Background" Value="{DynamicResource color.surface.panel}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="Padding" Value="8,4"/>
  </Style>

  <Style TargetType="{x:Type DatePicker}">
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="SelectedDateFormat" Value="Short"/>
  </Style>

  <Style TargetType="{x:Type primitives:DatePickerTextBox}">
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="SelectionBrush" Value="{DynamicResource color.accent.primary}"/>
  </Style>

  <Style TargetType="{x:Type Calendar}">
    <Setter Property="Background" Value="{DynamicResource color.surface.panel}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
  </Style>

  <Style TargetType="{x:Type primitives:CalendarItem}">
    <Setter Property="Background" Value="{DynamicResource color.surface.panel}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
  </Style>

  <Style TargetType="{x:Type primitives:CalendarDayButton}">
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
  </Style>

  <Style TargetType="{x:Type primitives:CalendarButton}">
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
  </Style>

  <Style TargetType="{x:Type CheckBox}">
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="Margin" Value="0,3"/>
  </Style>

  <Style TargetType="{x:Type RadioButton}">
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="Margin" Value="0,3"/>
  </Style>

  <Style TargetType="{x:Type ListBox}">
    <Setter Property="Background" Value="{DynamicResource color.surface.panel}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
  </Style>

  <Style TargetType="{x:Type ListBoxItem}">
    <Setter Property="Padding" Value="8,4"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Style.Triggers>
      <Trigger Property="IsSelected" Value="True">
        <Setter Property="Background" Value="{DynamicResource color.surface.selected}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="{x:Type ListView}" BasedOn="{StaticResource {x:Type ListBox}}"/>

  <Style TargetType="{x:Type GridViewColumnHeader}">
    <Setter Property="Background" Value="{DynamicResource CopperSkin.ChromeBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="Padding" Value="8,4"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>

  <Style TargetType="{x:Type TreeView}" BasedOn="{StaticResource {x:Type ListBox}}"/>
  <Style TargetType="{x:Type TreeViewItem}">
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="Padding" Value="4,2"/>
  </Style>

  <Style TargetType="{x:Type DataGrid}">
    <Setter Property="Background" Value="{DynamicResource color.surface.panel}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="GridLinesVisibility" Value="All"/>
    <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource color.surface.hover}"/>
    <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource color.surface.hover}"/>
    <Setter Property="RowBackground" Value="{DynamicResource color.surface.panel}"/>
    <Setter Property="AlternatingRowBackground" Value="{DynamicResource color.surface.deep}"/>
  </Style>

  <Style TargetType="{x:Type DataGridColumnHeader}">
    <Setter Property="Background" Value="{DynamicResource CopperSkin.ChromeBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="Padding" Value="8,4"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>

  <Style TargetType="{x:Type DataGridCell}">
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.surface.hover}"/>
    <Setter Property="Padding" Value="4,2"/>
  </Style>

  <Style TargetType="{x:Type Menu}">
    <Setter Property="Background" Value="{DynamicResource CopperSkin.ChromeBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>

  <Style TargetType="{x:Type ContextMenu}">
    <Setter Property="Background" Value="{DynamicResource color.surface.deep}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>

  <Style TargetType="{x:Type MenuItem}">
    <Setter Property="Background" Value="{DynamicResource color.surface.deep}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="Padding" Value="12,6"/>
    <Style.Triggers>
      <Trigger Property="IsHighlighted" Value="True">
        <Setter Property="Background" Value="{DynamicResource color.surface.hover}"/>
      </Trigger>
      <Trigger Property="IsEnabled" Value="False">
        <Setter Property="Foreground" Value="{DynamicResource color.text.disabled}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="{x:Type Separator}">
    <Setter Property="Background" Value="{DynamicResource color.border.default}"/>
    <Setter Property="Height" Value="1"/>
    <Setter Property="Margin" Value="8,4"/>
  </Style>

  <Style TargetType="{x:Type TabControl}">
    <Setter Property="Background" Value="{DynamicResource CopperSkin.PanelBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
  </Style>

  <Style TargetType="{x:Type TabItem}">
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.secondary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="Padding" Value="10,6"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Style.Triggers>
      <Trigger Property="IsSelected" Value="True">
        <Setter Property="Background" Value="{DynamicResource CopperSkin.PanelBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource color.accent.primary}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="{x:Type GroupBox}">
    <Setter Property="Foreground" Value="{DynamicResource color.accent.light}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="Padding" Value="10"/>
    <Setter Property="Margin" Value="0,0,0,10"/>
  </Style>

  <Style TargetType="{x:Type Expander}">
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="Background" Value="{DynamicResource color.surface.panel}"/>
  </Style>

  <Style TargetType="{x:Type primitives:Thumb}">
    <Setter Property="Background" Value="{DynamicResource color.accent.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.accent.light}"/>
  </Style>

  <Style TargetType="{x:Type InkCanvas}">
    <Setter Property="Background" Value="{DynamicResource color.surface.deep}"/>
  </Style>

  <Style TargetType="{x:Type FlowDocumentScrollViewer}">
    <Setter Property="Background" Value="{DynamicResource color.surface.deep}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
  </Style>

  <Style TargetType="{x:Type FlowDocumentReader}">
    <Setter Property="Background" Value="{DynamicResource color.surface.deep}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
  </Style>

  <Style TargetType="{x:Type FlowDocumentPageViewer}">
    <Setter Property="Background" Value="{DynamicResource color.surface.deep}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
  </Style>

  <Style TargetType="{x:Type DocumentViewer}">
    <Setter Property="Background" Value="{DynamicResource color.surface.deep}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
  </Style>

  <Style TargetType="{x:Type Frame}">
    <Setter Property="Background" Value="{DynamicResource color.surface.deep}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
  </Style>

  <Style TargetType="{x:Type Slider}">
    <Setter Property="Foreground" Value="{DynamicResource color.accent.primary}"/>
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
  </Style>

  <Style TargetType="{x:Type ProgressBar}">
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.accent.light}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="Height" Value="12"/>
  </Style>

  <Style TargetType="{x:Type ScrollBar}">
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.accent.primary}"/>
    <Setter Property="Width" Value="17"/>
  </Style>

  <Style TargetType="{x:Type ScrollViewer}">
    <Setter Property="Background" Value="{DynamicResource color.surface.deep}"/>
  </Style>

  <Style TargetType="{x:Type GridSplitter}">
    <Setter Property="Background" Value="{DynamicResource color.border.default}"/>
  </Style>

  <Style TargetType="{x:Type ToolTip}">
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.accent.primary}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="8,4"/>
  </Style>

  <Style TargetType="{x:Type StatusBar}">
    <Setter Property="Background" Value="{DynamicResource CopperSkin.ChromeBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.secondary}"/>
    <Setter Property="FontFamily" Value="Consolas"/>
    <Setter Property="FontSize" Value="11"/>
  </Style>

  <Style TargetType="{x:Type StatusBarItem}">
    <Setter Property="Foreground" Value="{DynamicResource color.text.secondary}"/>
    <Setter Property="Padding" Value="6,2"/>
  </Style>

  <Style TargetType="{x:Type ToolBar}">
    <Setter Property="Background" Value="{DynamicResource CopperSkin.ChromeBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
  </Style>

  <Style TargetType="{x:Type ToolBarOverflowPanel}">
    <Setter Property="Background" Value="{DynamicResource color.surface.deep}"/>
  </Style>

  <Style TargetType="{x:Type ToolBarTray}">
    <Setter Property="Background" Value="{DynamicResource CopperSkin.ChromeBrush}"/>
  </Style>

</ResourceDictionary>
