<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
  <!-- copperskin:allow-hardcoded-color-file default seed dictionary -->

  <SolidColorBrush x:Key="color.surface.deep" Color="#FF171221"/>
  <SolidColorBrush x:Key="color.surface.panel" Color="#FF241B32"/>
  <SolidColorBrush x:Key="color.surface.control" Color="#FF342640"/>
  <SolidColorBrush x:Key="color.surface.hover" Color="#FF49345B"/>
  <SolidColorBrush x:Key="color.surface.selected" Color="#FF5F3F78"/>
  <SolidColorBrush x:Key="color.accent.primary" Color="#FFB961FF"/>
  <SolidColorBrush x:Key="color.accent.light" Color="#FFFFA1F7"/>
  <SolidColorBrush x:Key="color.border.default" Color="#FF735A8C"/>
  <SolidColorBrush x:Key="color.text.primary" Color="#FFF9F2FF"/>
  <SolidColorBrush x:Key="color.text.secondary" Color="#FFD5BEDF"/>
  <SolidColorBrush x:Key="color.text.disabled" Color="#FF806B8F"/>
  <SolidColorBrush x:Key="color.status.success" Color="#FF59D98E"/>
  <SolidColorBrush x:Key="color.status.warning" Color="#FFFFCC44"/>
  <SolidColorBrush x:Key="color.status.danger" Color="#FFFF4466"/>

  <LinearGradientBrush x:Key="CopperSkin.ChromeBrush" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FF41304D" Offset="0"/>
    <GradientStop Color="#FF261B31" Offset="0.52"/>
    <GradientStop Color="#FF15111C" Offset="1"/>
  </LinearGradientBrush>
  <LinearGradientBrush x:Key="CopperSkin.PanelBrush" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FF322542" Offset="0"/>
    <GradientStop Color="#FF211A2D" Offset="1"/>
  </LinearGradientBrush>
  <LinearGradientBrush x:Key="CopperSkin.StripBrush" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#FF3B2A4E" Offset="0"/>
    <GradientStop Color="#FF231B30" Offset="0.62"/>
    <GradientStop Color="#FF191520" Offset="1"/>
  </LinearGradientBrush>
  <LinearGradientBrush x:Key="CopperSkin.ActiveBrush" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FFFFA1F7" Offset="0"/>
    <GradientStop Color="#FFB961FF" Offset="0.45"/>
    <GradientStop Color="#FF7447C7" Offset="1"/>
  </LinearGradientBrush>
  <LinearGradientBrush x:Key="CopperSkin.ButtonShine" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#55FFFFFF" Offset="0"/>
    <GradientStop Color="#00FFFFFF" Offset="0.42"/>
    <GradientStop Color="#24000000" Offset="1"/>
  </LinearGradientBrush>
  <LinearGradientBrush x:Key="CopperSkin.PanelSheen" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#18FFFFFF" Offset="0"/>
    <GradientStop Color="#00000000" Offset="0.34"/>
    <GradientStop Color="#22000000" Offset="1"/>
  </LinearGradientBrush>
  <DropShadowEffect x:Key="CopperSkin.SoftGlow" BlurRadius="12" ShadowDepth="0" Opacity="0.42" Color="#FFFFA1F7"/>
  <DropShadowEffect x:Key="CopperSkin.PanelShadow" BlurRadius="18" ShadowDepth="1" Opacity="0.34" Color="#FF000000"/>
  <DropShadowEffect x:Key="CopperSkin.NeonGlow" BlurRadius="16" ShadowDepth="0" Opacity="0.58" Color="#FFFFA1F7"/>

  <Style TargetType="{x:Type Window}">
    <Setter Property="Background" Value="{DynamicResource color.surface.deep}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="FontFamily" Value="Segoe UI"/>
    <Setter Property="FontSize" Value="12"/>
  </Style>

  <Style TargetType="{x:Type TextBlock}">
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="FontFamily" Value="Segoe UI"/>
    <Setter Property="FontSize" Value="12"/>
  </Style>

  <Style TargetType="{x:Type Label}">
    <Setter Property="Foreground" Value="{DynamicResource color.text.secondary}"/>
    <Setter Property="Padding" Value="2"/>
  </Style>

  <Style TargetType="{x:Type ContentControl}">
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="FontFamily" Value="Segoe UI"/>
  </Style>

  <Style TargetType="{x:Type HeaderedContentControl}" BasedOn="{StaticResource {x:Type ContentControl}}">
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
  </Style>

  <Style x:Key="CopperSkin.SectionTitle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
    <Setter Property="Foreground" Value="{DynamicResource color.accent.light}"/>
    <Setter Property="FontSize" Value="15"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Margin" Value="0,0,0,8"/>
  </Style>

  <Style x:Key="CopperSkin.PanelBorder" TargetType="{x:Type Border}">
    <Setter Property="Background" Value="{DynamicResource CopperSkin.StripBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="7"/>
    <Setter Property="Padding" Value="12"/>
    <Setter Property="Effect" Value="{DynamicResource CopperSkin.PanelShadow}"/>
  </Style>

  <Style x:Key="CopperSkin.FlatRepeatButton" TargetType="{x:Type RepeatButton}">
    <Setter Property="OverridesDefaultStyle" Value="True"/>
    <Setter Property="Focusable" Value="False"/>
    <Setter Property="IsTabStop" Value="False"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type RepeatButton}">
          <Border Background="{TemplateBinding Background}"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="CopperSkin.ButtonBase" TargetType="{x:Type primitives:ButtonBase}">
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="10,5"/>
    <Setter Property="MinHeight" Value="28"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type primitives:ButtonBase}">
          <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
            <Grid>
              <Border Background="{DynamicResource CopperSkin.ButtonShine}" CornerRadius="3" Opacity="0.72"/>
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Background" Value="{DynamicResource color.surface.hover}"/>
              <Setter Property="BorderBrush" Value="{DynamicResource color.accent.primary}"/>
              <Setter TargetName="Root" Property="Effect" Value="{DynamicResource CopperSkin.SoftGlow}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter Property="Background" Value="{DynamicResource color.accent.primary}"/>
              <Setter Property="Foreground" Value="#FFFFFFFF"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="{DynamicResource color.text.disabled}"/>
              <Setter TargetName="Root" Property="Opacity" Value="0.55"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="{x:Type Button}" BasedOn="{StaticResource CopperSkin.ButtonBase}"/>

  <Style TargetType="{x:Type RepeatButton}" BasedOn="{StaticResource CopperSkin.ButtonBase}">
    <Setter Property="Padding" Value="5,2"/>
    <Setter Property="MinHeight" Value="22"/>
  </Style>

  <Style TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource CopperSkin.ButtonBase}">
    <Style.Triggers>
      <Trigger Property="IsChecked" Value="True">
        <Setter Property="Background" Value="{DynamicResource color.accent.primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource color.accent.light}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="{x:Type TextBox}">
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="6,4"/>
    <Setter Property="CaretBrush" Value="{DynamicResource color.accent.primary}"/>
    <Setter Property="SelectionBrush" Value="{DynamicResource color.accent.primary}"/>
    <Setter Property="FontFamily" Value="Consolas"/>
  </Style>

  <Style TargetType="{x:Type RichTextBox}">
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="6,4"/>
    <Setter Property="CaretBrush" Value="{DynamicResource color.accent.primary}"/>
    <Setter Property="SelectionBrush" Value="{DynamicResource color.accent.primary}"/>
    <Setter Property="FontFamily" Value="Consolas"/>
    <Setter Property="MinHeight" Value="64"/>
  </Style>

  <Style TargetType="{x:Type PasswordBox}">
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="6,4"/>
  </Style>

  <Style TargetType="{x:Type ComboBox}">
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="8,4"/>
    <Setter Property="MinHeight" Value="30"/>
    <Setter Property="HorizontalContentAlignment" Value="Left"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="SnapsToDevicePixels" Value="True"/>
    <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
    <Setter Property="IsTextSearchEnabled" Value="True"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ComboBox}">
          <Grid>
            <ToggleButton x:Name="DropDownToggle"
                          Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          ClickMode="Press"
                          Focusable="False"
                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource TemplatedParent}}">
              <ToggleButton.Template>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                  <Border x:Name="Chrome"
                          Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          CornerRadius="4">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="32"/>
                      </Grid.ColumnDefinitions>
                      <Border Background="{DynamicResource CopperSkin.PanelSheen}" CornerRadius="4,0,0,4"/>
                      <Border Grid.Column="1"
                              Background="{DynamicResource CopperSkin.ChromeBrush}"
                              BorderBrush="{DynamicResource color.border.default}"
                              BorderThickness="1,0,0,0"
                              CornerRadius="0,3,3,0">
                        <Path Width="9"
                              Height="6"
                              Stretch="Fill"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Fill="{DynamicResource color.text.primary}"
                              Data="M 0 0 L 9 0 L 4.5 6 Z"/>
                      </Border>
                    </Grid>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource color.accent.primary}"/>
                      <Setter TargetName="Chrome" Property="Effect" Value="{DynamicResource CopperSkin.SoftGlow}"/>
                    </Trigger>
                    <Trigger Property="IsChecked" Value="True">
                      <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource color.accent.light}"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </ToggleButton.Template>
            </ToggleButton>
            <ContentPresenter x:Name="ContentSite"
                              Margin="{TemplateBinding Padding}"
                              IsHitTestVisible="False"
                              VerticalAlignment="Center"
                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              TextElement.Foreground="{TemplateBinding Foreground}"
                              Content="{TemplateBinding SelectionBoxItem}"
                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                              RecognizesAccessKey="True"/>
            <primitives:Popup x:Name="PART_Popup"
                              AllowsTransparency="True"
                              Focusable="False"
                              IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                              Placement="Bottom"
                              PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                              PopupAnimation="Fade">
              <Border Background="{DynamicResource color.surface.deep}"
                      BorderBrush="{DynamicResource color.accent.primary}"
                      BorderThickness="1"
                      CornerRadius="4"
                      MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                      MaxHeight="{TemplateBinding MaxDropDownHeight}"
                      Effect="{DynamicResource CopperSkin.SoftGlow}">
                <ScrollViewer CanContentScroll="True" Padding="3">
                  <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                </ScrollViewer>
              </Border>
            </primitives:Popup>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="DropDownToggle" Property="BorderBrush" Value="{DynamicResource color.accent.primary}"/>
            </Trigger>
            <Trigger Property="IsDropDownOpen" Value="True">
              <Setter TargetName="DropDownToggle" Property="BorderBrush" Value="{DynamicResource color.accent.light}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="{DynamicResource color.text.disabled}"/>
              <Setter TargetName="DropDownToggle" Property="Opacity" Value="0.55"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="{x:Type ComboBoxItem}">
    <Setter Property="Background" Value="{DynamicResource color.surface.panel}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="Padding" Value="8,4"/>
    <Setter Property="SnapsToDevicePixels" Value="True"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ComboBoxItem}">
          <Border x:Name="Root" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" BorderBrush="Transparent" BorderThickness="1" CornerRadius="3">
            <ContentPresenter VerticalAlignment="Center" RecognizesAccessKey="True"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource color.surface.hover}"/>
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource color.accent.primary}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource color.surface.selected}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="{DynamicResource color.text.disabled}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="{x:Type DatePicker}">
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="SelectedDateFormat" Value="Short"/>
  </Style>

  <Style TargetType="{x:Type primitives:DatePickerTextBox}">
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="SelectionBrush" Value="{DynamicResource color.accent.primary}"/>
  </Style>

  <Style TargetType="{x:Type Calendar}">
    <Setter Property="Background" Value="{DynamicResource color.surface.panel}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
  </Style>

  <Style TargetType="{x:Type primitives:CalendarItem}">
    <Setter Property="Background" Value="{DynamicResource color.surface.panel}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
  </Style>

  <Style TargetType="{x:Type primitives:CalendarDayButton}">
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
  </Style>

  <Style TargetType="{x:Type primitives:CalendarButton}">
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
  </Style>

  <Style TargetType="{x:Type CheckBox}">
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="Margin" Value="0,3"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type CheckBox}">
          <Grid SnapsToDevicePixels="True">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="22"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="Box" Width="16" Height="16" Background="{DynamicResource color.surface.deep}" BorderBrush="{DynamicResource color.border.default}" BorderThickness="1" CornerRadius="3" VerticalAlignment="Center">
              <Grid>
                <Border Background="{DynamicResource CopperSkin.ButtonShine}" CornerRadius="2" Opacity="0.55"/>
                <Path x:Name="CheckMark" Visibility="Collapsed" Stroke="{DynamicResource color.text.primary}" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M 3 8 L 6.6 11.5 L 13 4"/>
                <Border x:Name="IndeterminateMark" Visibility="Collapsed" Height="3" Width="9" Background="{DynamicResource color.text.primary}" CornerRadius="1" VerticalAlignment="Center" HorizontalAlignment="Center"/>
              </Grid>
            </Border>
            <ContentPresenter Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Center" RecognizesAccessKey="True"/>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource color.accent.primary}"/>
              <Setter TargetName="Box" Property="Effect" Value="{DynamicResource CopperSkin.SoftGlow}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Box" Property="Background" Value="{DynamicResource color.accent.primary}"/>
              <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource color.accent.light}"/>
              <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="{x:Null}">
              <Setter TargetName="Box" Property="Background" Value="{DynamicResource color.surface.selected}"/>
              <Setter TargetName="IndeterminateMark" Property="Visibility" Value="Visible"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="{DynamicResource color.text.disabled}"/>
              <Setter TargetName="Box" Property="Opacity" Value="0.55"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="{x:Type RadioButton}">
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="Margin" Value="0,3"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type RadioButton}">
          <Grid SnapsToDevicePixels="True">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="22"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="Outer" Width="16" Height="16" Background="{DynamicResource color.surface.deep}" BorderBrush="{DynamicResource color.border.default}" BorderThickness="1" CornerRadius="8" VerticalAlignment="Center">
              <Grid>
                <Ellipse Fill="{DynamicResource CopperSkin.ButtonShine}" Opacity="0.5"/>
                <Ellipse x:Name="Dot" Width="8" Height="8" Fill="{DynamicResource color.accent.light}" Visibility="Collapsed"/>
              </Grid>
            </Border>
            <ContentPresenter Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Center" RecognizesAccessKey="True"/>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Outer" Property="BorderBrush" Value="{DynamicResource color.accent.primary}"/>
              <Setter TargetName="Outer" Property="Effect" Value="{DynamicResource CopperSkin.SoftGlow}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Outer" Property="Background" Value="{DynamicResource color.surface.selected}"/>
              <Setter TargetName="Outer" Property="BorderBrush" Value="{DynamicResource color.accent.light}"/>
              <Setter TargetName="Dot" Property="Visibility" Value="Visible"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="{DynamicResource color.text.disabled}"/>
              <Setter TargetName="Outer" Property="Opacity" Value="0.55"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="{x:Type ListBox}">
    <Setter Property="Background" Value="{DynamicResource color.surface.panel}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
  </Style>

  <Style TargetType="{x:Type ListBoxItem}">
    <Setter Property="Padding" Value="8,4"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Style.Triggers>
      <Trigger Property="IsSelected" Value="True">
        <Setter Property="Background" Value="{DynamicResource color.surface.selected}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="{x:Type ListView}" BasedOn="{StaticResource {x:Type ListBox}}"/>

  <Style TargetType="{x:Type GridViewColumnHeader}">
    <Setter Property="Background" Value="{DynamicResource CopperSkin.ChromeBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="Padding" Value="8,4"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>

  <Style TargetType="{x:Type TreeView}">
    <Setter Property="Background" Value="{DynamicResource color.surface.panel}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="4"/>
    <Setter Property="SnapsToDevicePixels" Value="True"/>
    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
    <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
  </Style>

  <Style TargetType="{x:Type TreeViewItem}">
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Padding" Value="3,2"/>
    <Setter Property="MinHeight" Value="24"/>
    <Setter Property="SnapsToDevicePixels" Value="True"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type TreeViewItem}">
          <Grid SnapsToDevicePixels="True">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition/>
            </Grid.RowDefinitions>
            <ToggleButton x:Name="Expander"
                          Width="18"
                          Height="24"
                          Margin="0,0,2,0"
                          IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                          ClickMode="Press"
                          Focusable="False">
              <ToggleButton.Template>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                  <Grid Background="Transparent">
                    <Path x:Name="Arrow"
                          Width="7"
                          Height="7"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Data="M 0 0 L 0 7 L 5 3.5 Z"
                          Fill="{DynamicResource color.text.secondary}"
                          Stretch="Fill"/>
                  </Grid>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsChecked" Value="True">
                      <Setter TargetName="Arrow" Property="RenderTransform">
                        <Setter.Value>
                          <RotateTransform Angle="90" CenterX="3.5" CenterY="3.5"/>
                        </Setter.Value>
                      </Setter>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource color.accent.primary}"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </ToggleButton.Template>
            </ToggleButton>
            <Border x:Name="Selection"
                    Grid.Column="1"
                    Background="{TemplateBinding Background}"
                    BorderBrush="Transparent"
                    BorderThickness="1"
                    CornerRadius="3"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter x:Name="PART_Header"
                                ContentSource="Header"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True"
                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
            </Border>
            <ItemsPresenter x:Name="ItemsHost"
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="13,1,0,0"/>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="HasItems" Value="False">
              <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
            </Trigger>
            <Trigger Property="IsExpanded" Value="False">
              <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Selection" Property="Background" Value="{DynamicResource color.surface.hover}"/>
              <Setter TargetName="Selection" Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="Selection" Property="Background" Value="{DynamicResource color.surface.selected}"/>
              <Setter TargetName="Selection" Property="BorderBrush" Value="{DynamicResource color.accent.primary}"/>
              <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="{DynamicResource color.text.disabled}"/>
              <Setter TargetName="Selection" Property="Opacity" Value="0.55"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="{x:Type DataGrid}">
    <Setter Property="Background" Value="{DynamicResource color.surface.panel}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="GridLinesVisibility" Value="All"/>
    <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource color.surface.hover}"/>
    <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource color.surface.hover}"/>
    <Setter Property="RowBackground" Value="{DynamicResource color.surface.panel}"/>
    <Setter Property="AlternatingRowBackground" Value="{DynamicResource color.surface.deep}"/>
    <Setter Property="AlternationCount" Value="2"/>
  </Style>

  <Style TargetType="{x:Type DataGridRow}">
    <Setter Property="Background" Value="{DynamicResource color.surface.panel}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="SnapsToDevicePixels" Value="True"/>
    <Style.Triggers>
      <Trigger Property="AlternationIndex" Value="1">
        <Setter Property="Background" Value="{DynamicResource color.surface.deep}"/>
      </Trigger>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="{DynamicResource color.surface.hover}"/>
      </Trigger>
      <Trigger Property="IsSelected" Value="True">
        <Setter Property="Background" Value="{DynamicResource color.surface.selected}"/>
        <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="{x:Type DataGridColumnHeader}">
    <Setter Property="Background" Value="{DynamicResource CopperSkin.ChromeBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="Padding" Value="8,4"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>

  <Style TargetType="{x:Type DataGridCell}">
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.surface.hover}"/>
    <Setter Property="Padding" Value="4,2"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type DataGridCell}">
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="0,0,1,1"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter VerticalAlignment="Center"/>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="IsSelected" Value="True">
        <Setter Property="Background" Value="{DynamicResource color.surface.selected}"/>
        <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource color.accent.primary}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="{x:Type Menu}">
    <Setter Property="Background" Value="{DynamicResource CopperSkin.ChromeBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="SnapsToDevicePixels" Value="True"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Menu}">
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{DynamicResource color.border.default}"
                  BorderThickness="0,0,0,1">
            <ItemsPresenter Margin="2,0" KeyboardNavigation.TabNavigation="Cycle"/>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="{x:Type ContextMenu}">
    <Setter Property="Background" Value="{DynamicResource color.surface.deep}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="SnapsToDevicePixels" Value="True"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ContextMenu}">
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="4"
                  Padding="3"
                  Effect="{DynamicResource CopperSkin.SoftGlow}">
            <ScrollViewer CanContentScroll="True">
              <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
            </ScrollViewer>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="{x:Type MenuItem}">
    <Setter Property="Background" Value="{DynamicResource color.surface.deep}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="Padding" Value="14,7"/>
    <Setter Property="MinHeight" Value="30"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type MenuItem}">
          <Grid SnapsToDevicePixels="True">
            <Border x:Name="ItemChrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    Padding="{TemplateBinding Padding}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ContentPresenter x:Name="IconPresenter"
                                  Width="18"
                                  Margin="0,0,8,0"
                                  ContentSource="Icon"
                                  VerticalAlignment="Center"/>
                <ContentPresenter Grid.Column="1"
                                  ContentSource="Header"
                                  RecognizesAccessKey="True"
                                  VerticalAlignment="Center"/>
                <Path x:Name="SubmenuArrow"
                      Grid.Column="2"
                      Width="5"
                      Height="8"
                      Margin="14,0,0,0"
                      Fill="{DynamicResource color.text.secondary}"
                      Stretch="Fill"
                      Visibility="Collapsed"
                      Data="M 0 0 L 5 4 L 0 8 Z"/>
              </Grid>
            </Border>
            <primitives:Popup x:Name="PART_Popup"
                              AllowsTransparency="True"
                              Focusable="False"
                              IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                              Placement="Right"
                              PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                              PopupAnimation="Fade">
              <Border Background="{DynamicResource color.surface.deep}"
                      BorderBrush="{DynamicResource color.accent.primary}"
                      BorderThickness="1"
                      CornerRadius="4"
                      MinWidth="190"
                      Padding="3"
                      Effect="{DynamicResource CopperSkin.SoftGlow}">
                <ScrollViewer CanContentScroll="True">
                  <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
                </ScrollViewer>
              </Border>
            </primitives:Popup>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="Role" Value="TopLevelHeader">
              <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom"/>
              <Setter TargetName="ItemChrome" Property="Background" Value="Transparent"/>
              <Setter TargetName="ItemChrome" Property="BorderThickness" Value="1,0"/>
              <Setter Property="Padding" Value="18,11"/>
              <Setter TargetName="IconPresenter" Property="Visibility" Value="Collapsed"/>
            </Trigger>
            <Trigger Property="Role" Value="TopLevelItem">
              <Setter TargetName="ItemChrome" Property="Background" Value="Transparent"/>
              <Setter TargetName="ItemChrome" Property="BorderThickness" Value="1,0"/>
              <Setter Property="Padding" Value="18,11"/>
              <Setter TargetName="IconPresenter" Property="Visibility" Value="Collapsed"/>
            </Trigger>
            <Trigger Property="Role" Value="SubmenuHeader">
              <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible"/>
            </Trigger>
            <Trigger Property="HasItems" Value="False">
              <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Collapsed"/>
            </Trigger>
            <Trigger Property="IsHighlighted" Value="True">
              <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource color.surface.hover}"/>
              <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource color.accent.primary}"/>
              <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
            </Trigger>
            <Trigger Property="IsSubmenuOpen" Value="True">
              <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource color.surface.selected}"/>
              <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource color.accent.light}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="{DynamicResource color.text.disabled}"/>
              <Setter TargetName="ItemChrome" Property="Opacity" Value="0.55"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="{x:Type Separator}">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Separator}">
          <Border Height="1"
                  Margin="8,4"
                  Background="{DynamicResource color.border.default}"
                  Opacity="0.85"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="{x:Type TabControl}">
    <Setter Property="Background" Value="{DynamicResource CopperSkin.PanelBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type TabControl}">
          <Grid KeyboardNavigation.TabNavigation="Local">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TabPanel x:Name="HeaderPanel" Panel.ZIndex="1" IsItemsHost="True" KeyboardNavigation.TabIndex="1"/>
            <Border Grid.Row="1" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="0,4,4,4" KeyboardNavigation.TabNavigation="Local">
              <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent"/>
            </Border>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="{x:Type TabItem}">
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.secondary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="Padding" Value="10,6"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type TabItem}">
          <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4,4,0,0" Padding="{TemplateBinding Padding}" Margin="0,0,2,-1">
            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource color.surface.hover}"/>
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource color.accent.primary}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource CopperSkin.PanelBrush}"/>
              <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource color.accent.primary}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="{DynamicResource color.text.disabled}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="{x:Type GroupBox}">
    <Setter Property="Foreground" Value="{DynamicResource color.accent.light}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="Padding" Value="10"/>
    <Setter Property="Margin" Value="0,0,0,10"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type GroupBox}">
          <Grid SnapsToDevicePixels="True">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.RowSpan="2" Margin="0,10,0,0" Background="{DynamicResource CopperSkin.PanelBrush}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="6"/>
            <Border Background="{DynamicResource color.surface.panel}" BorderBrush="{DynamicResource color.border.default}" BorderThickness="1" CornerRadius="4" Padding="8,2" Margin="10,0,0,0" HorizontalAlignment="Left">
              <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"/>
            </Border>
            <ContentPresenter Grid.Row="1" Margin="{TemplateBinding Padding}"/>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="{x:Type Expander}">
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="Background" Value="{DynamicResource color.surface.panel}"/>
  </Style>

  <Style TargetType="{x:Type primitives:Thumb}">
    <Setter Property="Background" Value="{DynamicResource color.accent.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.accent.light}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type primitives:Thumb}">
          <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4">
            <Border Background="{DynamicResource CopperSkin.ButtonShine}" CornerRadius="3"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Effect" Value="{DynamicResource CopperSkin.SoftGlow}"/>
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource color.accent.light}"/>
            </Trigger>
            <Trigger Property="IsDragging" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource color.accent.light}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="{x:Type InkCanvas}">
    <Setter Property="Background" Value="{DynamicResource color.surface.deep}"/>
  </Style>

  <Style TargetType="{x:Type FlowDocumentScrollViewer}">
    <Setter Property="Background" Value="{DynamicResource color.surface.deep}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
  </Style>

  <Style TargetType="{x:Type FlowDocumentReader}">
    <Setter Property="Background" Value="{DynamicResource color.surface.deep}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
  </Style>

  <Style TargetType="{x:Type FlowDocumentPageViewer}">
    <Setter Property="Background" Value="{DynamicResource color.surface.deep}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
  </Style>

  <Style TargetType="{x:Type DocumentViewer}">
    <Setter Property="Background" Value="{DynamicResource color.surface.deep}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
  </Style>

  <Style TargetType="{x:Type Frame}">
    <Setter Property="Background" Value="{DynamicResource color.surface.deep}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
  </Style>

  <Style TargetType="{x:Type Slider}">
    <Setter Property="Foreground" Value="{DynamicResource color.accent.primary}"/>
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Slider}">
          <Grid Margin="2,7" SnapsToDevicePixels="True">
            <primitives:Track x:Name="PART_Track">
              <primitives:Track.DecreaseRepeatButton>
                <RepeatButton Style="{StaticResource CopperSkin.FlatRepeatButton}" Background="{DynamicResource color.accent.primary}"/>
              </primitives:Track.DecreaseRepeatButton>
              <primitives:Track.Thumb>
                <primitives:Thumb Width="14" Height="24" Background="{DynamicResource color.accent.light}" BorderBrush="{DynamicResource color.text.primary}"/>
              </primitives:Track.Thumb>
              <primitives:Track.IncreaseRepeatButton>
                <RepeatButton Style="{StaticResource CopperSkin.FlatRepeatButton}" Background="{DynamicResource color.surface.control}"/>
              </primitives:Track.IncreaseRepeatButton>
            </primitives:Track>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="{x:Type ProgressBar}">
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.accent.light}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.border.default}"/>
    <Setter Property="Height" Value="16"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ProgressBar}">
          <Grid x:Name="PART_Track" ClipToBounds="True" SnapsToDevicePixels="True">
            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="3"/>
            <Decorator x:Name="PART_Indicator" HorizontalAlignment="Left">
              <Border Background="{TemplateBinding Foreground}" CornerRadius="2" Margin="2">
                <Border Background="{DynamicResource CopperSkin.ButtonShine}" CornerRadius="2"/>
              </Border>
            </Decorator>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsIndeterminate" Value="True">
              <Setter TargetName="PART_Indicator" Property="HorizontalAlignment" Value="Stretch"/>
              <Setter TargetName="PART_Indicator" Property="Opacity" Value="0.65"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="{x:Type ScrollBar}">
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.accent.primary}"/>
    <Setter Property="Width" Value="15"/>
    <Setter Property="MinWidth" Value="15"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ScrollBar}">
          <Grid x:Name="Root" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
            <Grid.RowDefinitions>
              <RowDefinition Height="15"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="15"/>
            </Grid.RowDefinitions>
            <RepeatButton x:Name="LineUpButton" Grid.Row="0" Command="{x:Static ScrollBar.LineUpCommand}" Style="{StaticResource CopperSkin.FlatRepeatButton}" Background="{DynamicResource color.surface.panel}">
              <Path Width="7" Height="5" Fill="{DynamicResource color.text.secondary}" Stretch="Fill" Data="M 0 5 L 3.5 0 L 7 5 Z"/>
            </RepeatButton>
            <Border Grid.Row="1" Background="{DynamicResource color.surface.deep}" BorderBrush="{DynamicResource color.border.default}" BorderThickness="1,0">
              <primitives:Track x:Name="PART_Track" IsDirectionReversed="True">
                <primitives:Track.DecreaseRepeatButton>
                  <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Style="{StaticResource CopperSkin.FlatRepeatButton}" Background="Transparent"/>
                </primitives:Track.DecreaseRepeatButton>
                <primitives:Track.Thumb>
                  <primitives:Thumb Margin="2" Background="{DynamicResource color.accent.primary}" BorderBrush="{DynamicResource color.accent.light}"/>
                </primitives:Track.Thumb>
                <primitives:Track.IncreaseRepeatButton>
                  <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Style="{StaticResource CopperSkin.FlatRepeatButton}" Background="Transparent"/>
                </primitives:Track.IncreaseRepeatButton>
              </primitives:Track>
            </Border>
            <RepeatButton x:Name="LineDownButton" Grid.Row="2" Command="{x:Static ScrollBar.LineDownCommand}" Style="{StaticResource CopperSkin.FlatRepeatButton}" Background="{DynamicResource color.surface.panel}">
              <Path Width="7" Height="5" Fill="{DynamicResource color.text.secondary}" Stretch="Fill" Data="M 0 0 L 7 0 L 3.5 5 Z"/>
            </RepeatButton>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
              <Setter Property="Width" Value="Auto"/>
              <Setter Property="MinWidth" Value="0"/>
              <Setter Property="Height" Value="15"/>
              <Setter Property="MinHeight" Value="15"/>
              <Setter TargetName="Root" Property="LayoutTransform">
                <Setter.Value>
                  <RotateTransform Angle="-90"/>
                </Setter.Value>
              </Setter>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Effect" Value="{DynamicResource CopperSkin.SoftGlow}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="{x:Type ScrollViewer}">
    <Setter Property="Background" Value="{DynamicResource color.surface.deep}"/>
  </Style>

  <Style TargetType="{x:Type GridSplitter}">
    <Setter Property="Background" Value="{DynamicResource color.border.default}"/>
  </Style>

  <Style TargetType="{x:Type ToolTip}">
    <Setter Property="Background" Value="{DynamicResource color.surface.control}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource color.accent.primary}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="8,4"/>
    <Setter Property="HasDropShadow" Value="False"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ToolTip}">
          <Border Background="{DynamicResource CopperSkin.StripBrush}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" Padding="{TemplateBinding Padding}" Effect="{DynamicResource CopperSkin.SoftGlow}">
            <ContentPresenter RecognizesAccessKey="True"/>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="{x:Type StatusBar}">
    <Setter Property="Background" Value="{DynamicResource CopperSkin.ChromeBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.secondary}"/>
    <Setter Property="FontFamily" Value="Consolas"/>
    <Setter Property="FontSize" Value="11"/>
  </Style>

  <Style TargetType="{x:Type StatusBarItem}">
    <Setter Property="Foreground" Value="{DynamicResource color.text.secondary}"/>
    <Setter Property="Padding" Value="6,2"/>
  </Style>

  <Style TargetType="{x:Type ToolBar}">
    <Setter Property="Background" Value="{DynamicResource CopperSkin.ChromeBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource color.text.primary}"/>
  </Style>

  <Style TargetType="{x:Type ToolBarOverflowPanel}">
    <Setter Property="Background" Value="{DynamicResource color.surface.deep}"/>
  </Style>

  <Style TargetType="{x:Type ToolBarTray}">
    <Setter Property="Background" Value="{DynamicResource CopperSkin.ChromeBrush}"/>
  </Style>

</ResourceDictionary>
