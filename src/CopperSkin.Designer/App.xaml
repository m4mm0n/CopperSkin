    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <copper:CopperSkinThemeResources Theme="FL Grape"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>
</Application>
