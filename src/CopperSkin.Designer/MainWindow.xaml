<controls:CopperWindow x:Class="CopperSkin.Designer.MainWindow"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:controls="clr-namespace:CopperSkin.Wpf.Controls;assembly=CopperSkin.Wpf"
                       Title="CopperSkin Designer" Height="760" Width="1220" MinHeight="650" MinWidth="1050">
  <DockPanel>
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_File">
        <MenuItem Header="Export theme pack..." Click="ExportThemePack_Click"/>
        <MenuItem Header="Validate current pack" Click="ValidatePack_Click"/>
      </MenuItem>
      <MenuItem Header="_Theme">
        <MenuItem Header="Duplicate as custom" Click="DuplicateTheme_Click"/>
        <MenuItem Header="Show TaskDialog" Click="TaskDialog_Click"/>
      </MenuItem>
    </Menu>
    <StatusBar DockPanel.Dock="Bottom">
      <TextBlock Text="{Binding StatusText}"/>
    </StatusBar>
    <Grid Margin="14">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="240"/>
        <ColumnDefinition Width="430"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <Border Grid.Column="0" Style="{StaticResource CopperSkin.PanelBorder}" Margin="0,0,12,0">
        <DockPanel>
          <Image DockPanel.Dock="Top" Source="pack://application:,,,/Assets/mainlogo.png" Height="86" Stretch="Uniform" Margin="0,0,0,10"/>
          <TextBlock DockPanel.Dock="Top" Text="Theme catalog" Style="{StaticResource CopperSkin.SectionTitle}"/>
          <ListBox x:Name="ThemeList" ItemsSource="{Binding Themes}" DisplayMemberPath="Name" SelectionChanged="ThemeList_SelectionChanged"/>
        </DockPanel>
      </Border>
      <Border Grid.Column="1" Style="{StaticResource CopperSkin.PanelBorder}" Margin="0,0,12,0">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="Live token editor" Style="{StaticResource CopperSkin.SectionTitle}"/>
          <TextBlock DockPanel.Dock="Top" Text="Edit token values directly. #AARRGGBB colors apply instantly to the preview and running designer." Foreground="{DynamicResource color.text.secondary}" TextWrapping="Wrap" Margin="0,0,0,10"/>
          <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <TextBlock Text="Custom token value" Foreground="{DynamicResource color.text.secondary}"/>
            <TextBox x:Name="TokenValueBox" Text="{Binding SelectedToken.Value, UpdateSourceTrigger=PropertyChanged}" TextChanged="TokenValueBox_TextChanged"/>
            <Button Content="Apply token" Margin="0,8,0,0" Click="ApplyToken_Click"/>
          </StackPanel>
          <DataGrid x:Name="TokenGrid" ItemsSource="{Binding Tokens}" SelectedItem="{Binding SelectedToken, Mode=TwoWay}" AutoGenerateColumns="False" CanUserAddRows="False">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Token" Binding="{Binding Key}" Width="230" IsReadOnly="True"/>
              <DataGridTextColumn Header="Value" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="170"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>
      <Grid Grid.Column="2">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="170"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Style="{StaticResource CopperSkin.PanelBorder}" Margin="0,0,0,12">
          <DockPanel>
            <TextBlock Text="Live preview" Style="{StaticResource CopperSkin.SectionTitle}" DockPanel.Dock="Top"/>
            <WrapPanel>
              <Button Content="Primary button" Margin="0,0,8,8"/>
              <ToggleButton Content="Toggle" IsChecked="True" Margin="0,0,8,8"/>
              <CheckBox Content="Checkbox" IsChecked="True" Margin="0,0,8,8"/>
              <RadioButton Content="Radio" IsChecked="True" Margin="0,0,8,8"/>
              <ComboBox Width="160" SelectedIndex="0" Margin="0,0,8,8">
                <ComboBoxItem Content="Copper"/>
                <ComboBoxItem Content="Neon"/>
              </ComboBox>
              <ProgressBar Width="160" Value="68" Maximum="100" Margin="0,0,8,8"/>
              <Slider Width="180" Value="42" Maximum="100" Margin="0,0,8,8"/>
            </WrapPanel>
          </DockPanel>
        </Border>
        <TabControl Grid.Row="1">
          <TabItem Header="Controls">
            <ScrollViewer>
              <StackPanel Margin="12">
                <TextBlock Text="Forms and controls" Style="{StaticResource CopperSkin.SectionTitle}"/>
                <TextBox Text="Editable text box"/>
                <PasswordBox Password="password" Margin="0,8,0,0"/>
                <GroupBox Header="Grouped settings" Margin="0,10,0,0">
                  <StackPanel>
                    <Expander Header="Advanced controls" IsExpanded="True">
                      <StackPanel Margin="8">
                        <TextBlock Text="Density, chrome, motion, glow, radius, dialogs, and editor surfaces are first-class token groups." TextWrapping="Wrap"/>
                      </StackPanel>
                    </Expander>
                  </StackPanel>
                </GroupBox>
              </StackPanel>
            </ScrollViewer>
          </TabItem>
          <TabItem Header="Tracker">
            <controls:TrackerPreviewControl/>
          </TabItem>
          <TabItem Header="Lists">
            <Grid Margin="12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
              </Grid.ColumnDefinitions>
              <ListBox>
                <ListBoxItem Content="Theme token"/>
                <ListBoxItem Content="Brush alias"/>
                <ListBoxItem Content="Window chrome"/>
              </ListBox>
              <TreeView Grid.Column="1" Margin="12,0,0,0">
                <TreeViewItem Header="CopperSkin" IsExpanded="True">
                  <TreeViewItem Header="Core"/>
                  <TreeViewItem Header="WPF"/>
                  <TreeViewItem Header="Designer"/>
                </TreeViewItem>
              </TreeView>
            </Grid>
          </TabItem>
        </TabControl>
        <Border Grid.Row="2" Style="{StaticResource CopperSkin.PanelBorder}" Margin="0,12,0,0">
          <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="Diagnostics" Style="{StaticResource CopperSkin.SectionTitle}"/>
            <ListBox ItemsSource="{Binding Diagnostics}"/>
          </DockPanel>
        </Border>
      </Grid>
    </Grid>
  </DockPanel>
</controls:CopperWindow>
