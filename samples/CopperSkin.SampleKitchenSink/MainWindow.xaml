<controls:CopperWindow x:Class="CopperSkin.SampleKitchenSink.MainWindow"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:controls="clr-namespace:CopperSkin.Wpf.Controls;assembly=CopperSkin.Wpf"
                       Title="CopperSkin Kitchen Sink" Width="1180" Height="760" MinWidth="980" MinHeight="620">
  <DockPanel>
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_File">
        <MenuItem Header="Themed MessageBox" Click="MessageBox_Click"/>
        <MenuItem Header="Themed TaskDialog" Click="TaskDialog_Click"/>
      </MenuItem>
      <MenuItem Header="_View">
        <MenuItem Header="FL Grape" Click="Theme_Click"/>
        <MenuItem Header="Copper Desk" Click="Theme_Click"/>
        <MenuItem Header="Terminal Green" Click="Theme_Click"/>
        <MenuItem Header="Deep Red" Click="Theme_Click"/>
      </MenuItem>
    </Menu>
    <StatusBar DockPanel.Dock="Bottom">
      <TextBlock x:Name="StatusText" Text="Ready"/>
    </StatusBar>
    <Grid Margin="14">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <Border Style="{StaticResource CopperSkin.PanelBorder}" Margin="0,0,0,12">
        <DockPanel>
          <Image Source="pack://application:,,,/Assets/mainlogo.png" Height="80" Width="180" Stretch="Uniform" DockPanel.Dock="Left" Margin="0,0,14,0"/>
          <StackPanel>
            <TextBlock Text="CopperSkin WPF Theme Engine" Style="{StaticResource CopperSkin.SectionTitle}"/>
            <TextBlock Text="Runtime switching, full-window chrome, dialogs, standard controls, and custom drawing surfaces." Foreground="{DynamicResource color.text.secondary}" TextWrapping="Wrap"/>
            <ComboBox x:Name="ThemeCombo" Width="220" Margin="0,10,0,0" SelectionChanged="ThemeCombo_SelectionChanged"/>
          </StackPanel>
        </DockPanel>
      </Border>
      <TabControl Grid.Row="1">
        <TabItem Header="Standard controls">
          <ScrollViewer>
            <UniformGrid Columns="2" Margin="12">
              <Border Style="{StaticResource CopperSkin.PanelBorder}" Margin="0,0,12,12">
                <StackPanel>
                  <TextBlock Text="Buttons and inputs" Style="{StaticResource CopperSkin.SectionTitle}"/>
                  <WrapPanel>
                    <Button Content="Button" Margin="0,0,8,8"/>
                    <ToggleButton Content="Toggle" IsChecked="True" Margin="0,0,8,8"/>
                    <RepeatButton Content="Repeat" Margin="0,0,8,8"/>
                  </WrapPanel>
                  <TextBox Text="TextBox" Margin="0,6,0,0"/>
                  <PasswordBox Password="Password" Margin="0,8,0,0"/>
                  <ComboBox SelectedIndex="0" Margin="0,8,0,0" ToolTip="CopperSkin-owned ComboBox template">
                    <ComboBoxItem Content="Combo item"/>
                    <ComboBoxItem Content="Another item"/>
                  </ComboBox>
                  <CheckBox Content="CheckBox" IsChecked="True" Margin="0,8,0,0"/>
                  <RadioButton Content="RadioButton" IsChecked="True"/>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CopperSkin.PanelBorder}" Margin="0,0,0,12">
                <StackPanel>
                  <TextBlock Text="Range and status" Style="{StaticResource CopperSkin.SectionTitle}"/>
                  <Slider Value="42" Maximum="100" ToolTip="Theme-aware Slider track and thumb"/>
                  <ProgressBar Value="72" Maximum="100" Margin="0,12,0,0" ToolTip="Theme-aware ProgressBar fill"/>
                  <GroupBox Header="GroupBox" Margin="0,12,0,0">
                    <Expander Header="Expander" IsExpanded="True">
                      <TextBlock Text="Tooltips, labels, grouping, and density are styled." TextWrapping="Wrap"/>
                    </Expander>
                  </GroupBox>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CopperSkin.PanelBorder}" Margin="0,0,12,0">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition/>
                  </Grid.ColumnDefinitions>
                  <ListBox>
                    <ListBoxItem Content="ListBox item"/>
                    <ListBoxItem Content="Selected item" IsSelected="True"/>
                    <ListBoxItem Content="Third item"/>
                  </ListBox>
                  <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"/>
                  <TreeView Grid.Column="2">
                    <TreeViewItem Header="TreeView" IsExpanded="True">
                      <TreeViewItem Header="Node A"/>
                      <TreeViewItem Header="Node B"/>
                    </TreeViewItem>
                  </TreeView>
                </Grid>
              </Border>
              <Border Style="{StaticResource CopperSkin.PanelBorder}">
                <DataGrid AutoGenerateColumns="False" ItemsSource="{Binding Rows}" Height="220">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Control" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="State" Binding="{Binding State}" Width="*"/>
                  </DataGrid.Columns>
                </DataGrid>
              </Border>
            </UniformGrid>
          </ScrollViewer>
        </TabItem>
        <TabItem Header="Tracker drawing">
          <controls:TrackerPreviewControl/>
        </TabItem>
        <TabItem Header="Dialogs">
          <StackPanel Margin="18" Width="420" HorizontalAlignment="Left">
            <TextBlock Text="Themed dialogs" Style="{StaticResource CopperSkin.SectionTitle}"/>
            <Button Content="Open Copper MessageBox" Click="MessageBox_Click"/>
            <Button Content="Open Copper TaskDialog" Click="TaskDialog_Click" Margin="0,8,0,0"/>
          </StackPanel>
        </TabItem>
      </TabControl>
    </Grid>
  </DockPanel>
</controls:CopperWindow>
